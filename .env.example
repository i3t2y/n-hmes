# ═══════════════════════════════════════════════════════════════════════════
#  HermesFace — Environment Configuration
#  Deploy Hermes Agent on HuggingFace Spaces
# ═══════════════════════════════════════════════════════════════════════════
#
#  Usage:
#    Local Docker  →  cp .env.example .env  →  fill in values  →  docker run --env-file .env
#    HF Spaces     →  Set each variable as a "Repository Secret" in Space Settings
#
#  Legend:
#    [REQUIRED]      Must be set, or data persistence will not work
#    [RECOMMENDED]   Strongly recommended for production use
#    [OPTIONAL]      Fine-tune behavior; safe to leave empty
#
# ═══════════════════════════════════════════════════════════════════════════


# ─── DATA PERSISTENCE ────────────────────────────────────────────────────
#
# HermesFace auto-syncs the /opt/data directory to a private HF Dataset
# repo, so your conversations, skills, memories, and config survive restarts.
# Without these variables, all data is lost when the Space restarts.
#
# HuggingFace Access Token with WRITE permission.
# Create one at: https://huggingface.co/settings/tokens
# Scopes needed: read + write access to your repos.
#
# [REQUIRED]
#
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Target Dataset repository for data backup.
# Format: your-username/repo-name
# Example: your-name/HermesFace-data
#
#   Manual mode (default): create the repo yourself, then set this variable.
#   Auto mode (AUTO_CREATE_DATASET=true): if not set, HermesFace derives
#     it from your SPACE_ID → "your-username/HermesFace-data".
#
# [OPTIONAL in auto mode]
#
# HERMES_DATASET_REPO=your-username/HermesFace-data

# Whether to auto-create the Dataset repo if it doesn't exist.
# When true: HermesFace creates a PRIVATE dataset repo on first startup.
#
# [OPTIONAL]  Default: true
#
AUTO_CREATE_DATASET=true

# How often (in seconds) to back up data to the Dataset repo.
# Lower values = safer but more API calls to HuggingFace.
#
# [OPTIONAL]  Default: 60
#
# SYNC_INTERVAL=60


# ─── LLM PROVIDERS ────────────────────────────────────────────────────────
#
# HermesFace passes ALL environment variables directly to Hermes Agent.
# Any provider that Hermes supports works out of the box — just set the
# API key as a Secret in your HF Space settings.
#
# [RECOMMENDED] At least one of the following for AI conversations
#
# OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NOUS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GOOGLE_API_KEY=AIza...
# MISTRAL_API_KEY=mis-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ─── MESSAGING PLATFORMS ─────────────────────────────────────────────────
#
# Hermes Agent supports 16+ messaging platforms natively.
# Configure via environment variables.
#
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# DISCORD_BOT_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ─── PERFORMANCE ──────────────────────────────────────────────────────────
#
# Timezone for log timestamps and scheduled tasks.
#
# [OPTIONAL]  Default: UTC
#
# TZ=Asia/Shanghai


# ─── HERMES AGENT CONFIG ─────────────────────────────────────────────────
#
# Agent name displayed in messaging platforms.
#
# [OPTIONAL]  Default: HermesFace
#
# AGENT_NAME=HermesFace


# ═══════════════════════════════════════════════════════════════════════════
#  Hermes Agent 官方环境变量
# ═══════════════════════════════════════════════════════════════════════════
#
#  HermesFace 启动 Hermes Agent 时透传整个环境（env=os.environ.copy()），
#  因此 Hermes Agent 官方文档中列出的 **所有** 环境变量在 HF Spaces / Docker 中
#  设置后均可直接生效。
#
#  常见类别（仅列举部分）：
#    API Keys: OPENROUTER_API_KEY, OPENAI_API_KEY, ANTHROPIC_API_KEY,
#              NOUS_API_KEY, GOOGLE_API_KEY, MISTRAL_API_KEY
#    Messaging: TELEGRAM_BOT_TOKEN, DISCORD_BOT_TOKEN, SLACK_BOT_TOKEN
#    Terminal:  TERMINAL_BACKEND, TERMINAL_TIMEOUT
#    Browser:   BROWSERBASE_API_KEY, BROWSERBASE_PROJECT_ID
#
# ═══════════════════════════════════════════════════════════════════════════
#
# ═══════════════════════════════════════════════════════════════════════════
#  HermesFace 新增变量一览（仅本仓库脚本使用）
# ═══════════════════════════════════════════════════════════════════════════
#
# ─── 持久化 (HuggingFace Dataset) ───────────────────────────────────────
#   HF_TOKEN                  [必填] HF 访问令牌，需具备写入权限
#   HERMES_DATASET_REPO       [可选] 备份用 Dataset 仓库，如 your-name/HermesFace-data
#   AUTO_CREATE_DATASET       [可选] 是否自动创建仓库，默认 true
#   SYNC_INTERVAL             [可选] 备份间隔（秒），默认 60
#   HF_HUB_DOWNLOAD_TIMEOUT   [可选] 下载超时（秒），默认 300
#   HF_HUB_UPLOAD_TIMEOUT     [可选] 上传超时（秒），默认 600
#
# ─── LLM / 对话 API（至少配置其一以启用 AI 对话）────────────────────────
#   所有 Hermes Agent 支持的 API Key 环境变量均可直接使用，无需额外配置。
#
# ─── 消息渠道 ─────────────────────────────────────────────────────────
#   Telegram、Discord、Slack、WhatsApp、Signal 等消息渠道均可通过环境变量配置。
#
# ─── HuggingFace Spaces 运行时（HF 自动注入，一般无需手动设）────────────
#   SPACE_HOST                当前 Space 域名，如 xxx.hf.space
#   SPACE_ID                  仓库 ID，如 username/HermesFace
#
# ─── 运行配置 ───────────────────────────────────────────────────────
#   AGENT_NAME                [可选] Agent 名称，默认 HermesFace
#   TZ                        [可选] 时区，如 Asia/Shanghai
#
# ═══════════════════════════════════════════════════════════════════════════
